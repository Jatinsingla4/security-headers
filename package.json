{
  "name": "security-headers",
  "version": "1.0.0",
  "description": "Security Headers - Broken Link Detection & Security Headers System",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run worker:dev\" \"npm run dev:dashboard\"",
    "dev:frontend": "npm run dev:dashboard",
    "dev:backend": "npm run worker:dev",
    "build": "npm run build:dashboard",
    "start": "npm run start:dashboard",
    "crawl": "tsx backend/crawler/index.ts",
    "crawl:ci": "tsx backend/crawler/index.ts --ci",
    "worker:dev": "wrangler dev backend/index.ts",
    "worker:deploy": "wrangler deploy backend/index.ts",
    "dev:dashboard": "next dev frontend -p 3000",
    "build:dashboard": "next build frontend",
    "start:dashboard": "next start frontend",
    "typecheck": "tsc --noEmit",
    "lint": "eslint frontend/ backend/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20241106.0",
    "@trpc/server": "^11.0.0",
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "25.5.2",
    "@types/react": "19.2.14",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.80.0"
  }
}
